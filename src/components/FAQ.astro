---
/**
 * FAQ — EVERY question and answer rendered fully visible on page load.
 * No <details>, no accordions, no toggles, ever (Rule 24: Google can't
 * click). Emits FAQPage JSON-LD automatically (Rule 27).
 *
 * Content rules (Rule 30): reword PAA questions (never verbatim); answer
 * briefly (a couple dozen words); answers accept HTML so a brief answer
 * can carry an editorial link to its deep supporting page.
 */
interface Faq { q: string; a: string }
interface Props {
  faqs: ReadonlyArray<Faq>;
  heading?: string;
}
const { faqs = [], heading = 'Frequently Asked Questions' } = Astro.props;

const schema =
  faqs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : null;
---

{faqs.length > 0 && (
  <section class="section">
    <div class="container">
      <h2>{heading}</h2>
      {faqs.map((f) => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p set:html={f.a} />
        </div>
      ))}
    </div>
  </section>
)}
{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
