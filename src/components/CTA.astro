---
/**
 * CTA BAND — closes every page with the fastest path to a call (Rule 21).
 */
import { business as b, telHref } from '../config/business';

interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = `Ready to Get Started in ${b.address.city}?`,
  sub = 'Call or text now for a fast, free estimate, or send your details and we\'ll get right back to you.',
} = Astro.props;
---

<section class="section cta-band">
  <div class="container">
    <h2>{heading}</h2>
    <p>{sub}</p>
    <div class="cta-band__actions">
      <a class="btn btn--primary" href={telHref}>Call {b.phoneDisplay}</a>
      <a class="btn btn--outline" href="/contact/">Get a Free Estimate</a>
    </div>
  </div>
</section>
