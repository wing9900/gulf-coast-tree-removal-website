---
/**
 * REVIEWS, Rule 23: on-page reviews must be EMBEDDED LIVE from the GBP
 * in recognizable Google formatting. Never re-typed testimonial text,
 * never stock gray-avatar cards.
 *
 * FILL-IN STEP: drop the live GBP review embed (e.g. Elfsight/EmbedSocial
 * Google Reviews widget, 5–6 reviews horizontal) into the marked slot.
 * The aggregate card above it stays as plain crawlable HTML for
 * Google + AI models regardless of what the widget renders.
 */
import { business as b } from '../config/business';

interface Props { heading?: string }
const { heading = `What Customers in ${b.address.city} Say` } = Astro.props;
const hasRating = b.gbp.ratingValue > 0 && b.gbp.reviewCount > 0;
---

<section class="section section--alt">
  <div class="container">
    <h2>{heading}</h2>
    <p class="reviews-sub">We're proud to be the top-rated choice for exceptional tree service.</p>
    <p class="reviews-sub">See what your neighbors are saying.</p>

    {hasRating && (
      <div class="rating-card">
        <span class="rating-card__excellent">Excellent</span>
        <span class="stars" aria-hidden="true">★★★★★</span>
        <p class="rating-card__count">5-Star Rated on Google across {b.gbp.reviewCount}+ reviews</p>
      </div>
    )}

    <!-- ═══ LIVE GBP REVIEW EMBED GOES HERE (replace this placeholder) ═══ -->
    <div class="gbp-embed-placeholder">
      Live Google Business Profile review embed, 5–6 reviews, horizontal layout
    </div>

    {b.gbp.profileUrl && (
      <p class="reviews-cta">
        <a class="btn btn--reviews" href={b.gbp.profileUrl} rel="noopener">
          <svg viewBox="0 0 48 48" width="20" height="20" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
          See All Our Reviews on Google
        </a>
      </p>
    )}
  </div>
</section>
