---
/**
 * HERO — STATIC only (Rule 21: no animated/rotating heroes; they bounce).
 * H1 + subheadline + primary CTA + tap-to-call phone are all visible
 * without scrolling on a phone. The H1 is the largest text on the page
 * (CSS guarantees it) — Google infers the primary heading from size.
 *
 * IMAGE FILL-IN STEP: swap the gradient for the single best real photo of
 * the core offering (background-image or <img> with descriptive filename
 * + specific alt text, compressed WebP — Rule 26). Never clickable
 * unless labeled. No stock, no AI imagery for local proof (Rule 29).
 */
import { telHref, business as b } from '../config/business';

interface HeroImage {
  src: string;
  srcset?: string;
  mobileSrc?: string; // art-directed portrait crop for phones
  alt: string;
  width: number;
  height: number;
}
interface Props {
  eyebrow?: string;
  h1: string;
  benefits?: ReadonlyArray<string>;
  reviewers?: ReadonlyArray<{ img?: string; initials?: string; bg?: string }>;
  ctaLabel?: string;
  ctaHref?: string;
  image?: HeroImage; // real job photo (Rule 21/26): falls back to gradient when absent
}
const { eyebrow, h1, benefits = [], reviewers = [], ctaLabel = 'Get a Free Estimate', ctaHref = '/contact/', image } = Astro.props;
const hasRating = b.gbp.ratingValue > 0 && b.gbp.reviewCount > 0;
---

<section class={image ? 'hero hero--photo' : 'hero'}>
  {image && (
    <picture>
      {image.mobileSrc && (
        <source media="(max-width: 47.99rem)" srcset={image.mobileSrc} width="816" height="1020" />
      )}
      <img
        class="hero__img"
        src={image.src}
        srcset={image.srcset}
        sizes="100vw"
        alt={image.alt}
        width={image.width}
        height={image.height}
        fetchpriority="high"
        decoding="async"
      />
    </picture>
  )}
  <div class="container">
    {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
    <h1>{h1}</h1>
    {benefits.length > 0 && (
      <p class="hero__benefits">
        {benefits.map((item) => <span>{item}</span>)}
      </p>
    )}
    {hasRating && (
      <a class="hero__pill" href={b.gbp.profileUrl} aria-label="Read our Google reviews">
        {reviewers.length > 0 && (
          <span class="hero__avatars" aria-hidden="true">
            {reviewers.map((r) =>
              r.img ? (
                <img class="hero__avatar hero__avatar--photo" src={r.img} alt="" width="34" height="34" loading="lazy" decoding="async" />
              ) : (
                <span class="hero__avatar" style={`background:${r.bg ?? '#5c6bc0'}`}>{r.initials}</span>
              )
            )}
          </span>
        )}
        <span class="hero__pill-stars" aria-hidden="true">★★★★★</span>
        <span class="hero__pill-text">{b.gbp.ratingValue.toFixed(1)} · {b.gbp.reviewCount}+ Google Reviews</span>
        <svg class="hero__pill-g" viewBox="0 0 48 48" width="22" height="22" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
      </a>
    )}
    <div class="hero__cta">
      <a class="btn btn--primary" href={telHref}>Call {b.phoneDisplay}</a>
      <a class="btn btn--outline" href={ctaHref}>{ctaLabel}</a>
    </div>
  </div>
</section>
