---
/**
 * SOCIAL PROOF BAND — sits directly under the hero (Rule 23).
 * Aggregate rating + review count in large type, pulled live from config
 * (never hidden, never behind a "read more"). Badges link to their proof.
 * FILL-IN STEP: replace text badges with linked logo images (descriptive
 * filename + alt) once assets exist.
 */
import { business as b } from '../config/business';

interface BadgeImg { src: string; width: number; height: number }
interface Props {
  badges?: ReadonlyArray<{ label: string; href?: string; img?: BadgeImg }>;
  reviewers?: ReadonlyArray<{ img?: string; initials?: string; bg?: string }>;
}
const { badges = [], reviewers = [] } = Astro.props;
const hasRating = b.gbp.ratingValue > 0 && b.gbp.reviewCount > 0;
---

<div class="proof-band">
  <div class="container">
    <div class="proof-band__inner">
      {hasRating ? (
        <span class="proof-band__rating">
          {reviewers.length > 0 && (
            <span class="proof-band__avatars" aria-hidden="true">
              {reviewers.map((r) =>
                r.img ? (
                  <img class="proof-band__avatar proof-band__avatar--photo" src={r.img} alt="" width="34" height="34" loading="lazy" decoding="async" />
                ) : (
                  <span class="proof-band__avatar" style={`background:${r.bg ?? '#5c6bc0'}`}>{r.initials}</span>
                )
              )}
            </span>
          )}
          <span class="proof-band__rating-col">
            <span class="stars" aria-hidden="true">★★★★★</span>
            <span class="proof-band__count-line">
              <strong class="proof-band__score">{b.gbp.ratingValue.toFixed(1)}</strong>
              {' · '}
              <span class="proof-band__count">{b.gbp.reviewCount}+ reviews</span>
            </span>
          </span>
          <svg class="proof-band__g" viewBox="0 0 48 48" width="22" height="22" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
        </span>
      ) : (
        <span class="proof-band__rating"><!-- FILL-IN: set gbp.ratingValue + reviewCount in business.ts -->[★ Rating · Review Count from GBP]</span>
      )}
      <span class="proof-band__badges">
      {badges.map((badge) => {
        const inner = badge.img ? (
          <img src={badge.img.src} alt={badge.label} width={badge.img.width} height={badge.img.height} loading="lazy" decoding="async" />
        ) : (
          badge.label
        );
        return badge.href ? (
          <a class={badge.img ? 'proof-band__badge proof-band__badge--img' : 'proof-band__badge'} href={badge.href}>{inner}</a>
        ) : (
          <span class={badge.img ? 'proof-band__badge proof-band__badge--img' : 'proof-band__badge'}>{inner}</span>
        );
      })}
      </span>
    </div>
  </div>
</div>

<style>

/* ── Social proof band — dark strip directly under the hero ── */
.proof-band {
  background: var(--c-primary-dark); color: #fff; border-top: 3px solid var(--c-accent);
  /* Seam guard: on high-DPR mobile, fractional-pixel rounding between this
     band and the next section can let the cream body background show as a
     thin strip. Diagnosis ruled out margin leaks (sections use padding;
     no margins exist on the band's children), so this paints 1px of the
     band's own color past its bottom edge with zero layout impact. */
  box-shadow: 0 1px 0 0 var(--c-primary-dark);
}
.proof-band__inner {
  display: flex; flex-direction: column; align-items: center;
  gap: 0.8rem; padding-block: 1rem; text-align: center;
}
.proof-band__badges { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 0.6rem 0.9rem; }
/* The review pill: white capsule on the dark band, overlapping avatar
   stack, gold stars over the score line. Reads at a glance as "real
   people, real rating, on Google." */
.proof-band__rating {
  display: inline-flex; align-items: center; gap: 0.7rem;
  background: #fff; color: var(--c-ink);
  border-radius: 999px; padding: 0.45rem 0.75rem 0.45rem 0.55rem;
  box-shadow: 0 4px 14px rgb(0 0 0 / 0.28);
  font-size: 1rem; font-weight: 600;
}
.proof-band__g { flex: none; }
.proof-band__rating-col { display: inline-flex; flex-direction: column; line-height: 1.25; }
.proof-band__rating .stars { color: var(--c-star); font-size: 1.02rem; letter-spacing: 0.1em; }
.proof-band__score { font-size: 1.05rem; font-weight: 700; font-family: var(--font-display); letter-spacing: 0.02em; color: var(--c-ink); }
.proof-band__count-line { font-size: var(--fs-small); color: var(--c-ink-soft); white-space: nowrap; }
.proof-band__count { color: var(--c-primary); font-weight: 600; }
a.proof-band__count:hover { color: var(--c-primary-dark); }
.proof-band__avatars { display: inline-flex; padding-left: 0.2rem; }
.proof-band__avatar {
  display: inline-flex; align-items: center; justify-content: center;
  width: 36px; height: 36px; border-radius: 50%; margin-right: -11px;
  border: 2px solid #fff; box-shadow: 0 1px 3px rgb(0 0 0 / 0.2); color: #fff;
  font-family: var(--font-display); font-size: 0.85rem; font-weight: 700; letter-spacing: 0.03em;
}
.proof-band__avatar:last-child { margin-right: 0; }
.proof-band__avatar--photo { object-fit: cover; background: #fff; padding: 0; }
.proof-band__badge {
  font-size: var(--fs-small); font-weight: 600; color: var(--c-accent-soft); text-decoration: none;
  border: 1px solid rgb(255 255 255 / 0.25); border-radius: 999px; padding: 0.35rem 0.85rem;
}
a.proof-band__badge:hover { border-color: var(--c-accent); color: #fff; background: rgb(242 111 31 / 0.12); }
/* Image badges (ISA logo): no pill, no ring, ever. Compound selector
   outranks the base rule and the anchor hover above. */
.proof-band__badge.proof-band__badge--img,
a.proof-band__badge.proof-band__badge--img:hover {
  border: 0; padding: 0; border-radius: 0; background: none;
}
.proof-band__badge--img img { height: 46px; width: auto; border-radius: 3px; }

@media (min-width: 48rem) {
  .proof-band__inner { flex-direction: row; justify-content: space-between; text-align: left; gap: 0.75rem 1.5rem; }
  .proof-band__badges { justify-content: flex-end; }
  .proof-band__badge--img img { height: 56px; }
}

@media (min-width: 64rem) {
  .proof-band__avatar { width: 44px; height: 44px; margin-right: -13px; }
  .proof-band__g { width: 26px; height: 26px; }
  .proof-band__rating { font-size: 1.05rem; gap: 0.8rem; padding: 0.55rem 1.3rem 0.55rem 0.65rem; }
  .proof-band__rating .stars { font-size: 1.2rem; }
  .proof-band__score { font-size: 1.25rem; }
  .proof-band__count-line { font-size: 1rem; }
  .proof-band__badge { font-size: 1rem; padding: 0.45rem 1.05rem; }
  .proof-band__badge--img img { height: 64px; }
}
</style>
