---
/**
 * 404 — keeps lost visitors (and crawlers following stale links) inside
 * the site with paths back to the money pages.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { business as b, telHref } from '../config/business';
---

<BaseLayout title={`Page Not Found | ${b.name}`} description={`That page doesn't exist. Head back to ${b.name}'s services or call ${b.phoneDisplay} for immediate help.`}>
  <section class="hero">
    <div class="container">
      <h1>That Page Isn't Here</h1>
      <p class="hero__sub">The link may be old or mistyped. The fastest fix: call us, or jump back to our services.</p>
      <div class="hero__cta">
        <a class="btn btn--primary" href={telHref}>Call {b.phoneDisplay}</a>
        <a class="btn btn--outline" href="/services/">Browse All Services</a>
      </div>
    </div>
  </section>
</BaseLayout>
