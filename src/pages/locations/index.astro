---
/**
 * LOCATIONS HUB (Rule 31) — PHASE 2 ONLY.
 * Geographic/landmark pages hang off this hub once the rank map shows
 * Top 3% at/above the topical-relevance threshold. Do NOT populate at
 * launch — location pages built before topical authority exists do
 * nothing (Rule 4).
 *
 * While the locations collection is empty, this page ships with
 * noindex automatically. When Phase 2 begins: add location .md files
 * (from _TEMPLATE.md), and add /locations/ to the Header nav.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { business as b, cityState, telHref } from '../../config/business';

const locations = (await getCollection('locations')).sort((a, z) =>
  a.data.kind === z.data.kind
    ? a.data.order - z.data.order
    : a.data.kind === 'town' ? -1 : 1
);

const title = `Areas We Serve in ${cityState} | ${b.name}`;
const description = `Towns and neighborhoods across the ${cityState} region served by ${b.name}. Find detailed local tree service information for your area.`;
---

<BaseLayout title={title} description={description} noindex={locations.length === 0}>
  <section class="hero">
    <div class="container">
      <h1>Areas We Serve Across the {b.address.city} Region</h1>
      <p class="hero__sub">
        Local service details for the towns and neighborhoods we work in most around {cityState}.
      </p>
      <div class="hero__cta">
        <a class="btn btn--primary" href={telHref}>Call {b.phoneDisplay}</a>
        <a class="btn btn--outline" href="/contact/">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {locations.length > 0 ? (
        <div class="grid grid--3">
          {locations.map((loc) => (
            <div class="card">
              <h2 class="card-title">{loc.data.title}</h2>
              <p><a href={`/locations/${loc.id}/`}>Service details for {loc.data.shortName ?? loc.data.title}</a></p>
            </div>
          ))}
        </div>
      ) : (
        <p>
          <!-- Placeholder while collection is empty (page is noindexed) -->
          Location pages are added here during the geographic expansion phase.
        </p>
      )}
    </div>
  </section>

  <CTA />
</BaseLayout>
