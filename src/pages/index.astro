---
/**
 * ═══════════════════════════════════════════════════════════════════
 * HOMEPAGE = THE GBP LANDING PAGE (the URL in the GBP's website field).
 * Implements the Rule 13 blueprint in exact order, and carries all 8
 * Rule 12 consistency signals:
 *   1. Title tag: primary category + city (formula below)
 *   2. H1: primary category + city + hook (homepage.ts)
 *   3. Google Maps embed of the GBP pin (MapNAP)
 *   4. Secondary categories in H2 subheadings (category loop)
 *   5. Live GBP review widget (ReviewsEmbed)
 *   6. Address matching GBP character-for-character (config-driven)
 *   7. Phone matching character-for-character (config-driven)
 *   8. LocalBusiness schema (BaseLayout → LocalBusinessSchema)
 * ═══════════════════════════════════════════════════════════════════
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ReviewsEmbed from '../components/ReviewsEmbed.astro';
import FAQ from '../components/FAQ.astro';
import MapNAP from '../components/MapNAP.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import CTA from '../components/CTA.astro';
import { business as b, cityState } from '../config/business';
import { homepage as hp } from '../config/homepage';

// Rule 17 title formula: [Primary GBP category] + [City, ST] + [Brand],
// with the optional long-title keyword tail appended past truncation.
const title =
  `${b.primaryCategory} in ${cityState} | ${b.name}` +
  (b.seo.titleTail ? ` | ${b.seo.titleTail}` : '');

const categories = (await getCollection('categories')).sort(
  (a, z) => a.data.order - z.data.order
);
---

<BaseLayout title={title} description={b.seo.homepageMetaDescription}>
  <!-- 1–3. H1 + subheadline + primary CTA + tap-to-call phone, above the fold -->
  <Hero h1={hp.hero.h1} benefits={hp.hero.benefits} reviewers={hp.googleReviewers} ctaLabel={hp.hero.ctaLabel} image={hp.hero.image} />

  <!-- 4. Social-proof band: rating + review count + badges -->

  <!-- 5. Opening paragraph: visitor's situation + USP (Rule 21, never "Welcome to…") -->
  <section class="section">
    <div class="container intro-split">
      <div class="intro-split__text">
        <h2>{hp.introH2}</h2>
        <p class="lead">{hp.openingParagraph}</p>
      </div>
      <img
        class="intro-split__media"
        src="/images/technical-tree-removal-near-power-lines-pasadena-tx.webp"
        alt="Gulf Coast climber roped in at the top of a bare spar beside power lines during a hazardous tree removal in Pasadena, TX"
        width="765" height="1020" loading="lazy" decoding="async"
      />
    </div>
  </section>

  <!-- 6. Why Choose Us, high on the page, static grid (no carousel) -->
  <section class="section section--alt">
    <div class="container">
      <p class="eyebrow">Why choose us</p>
      <h2>Why {b.address.city} Chooses {b.name}</h2>
      <div class="grid grid--4">
        {hp.whyChooseUs.map((item) => (
          <div class="card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. Secondary category sections: each GBP category gets an H2 +
       50–100 words + an EDITORIAL link (in-paragraph) to its category
       page, the links that actually pass authority (Rule 16). -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">What we do</p>
      <h2>Our {b.primaryCategory} Services in {b.address.city}</h2>
      {categories.map((cat) => (
        <article class="card card--flow">
          <h2 class="card-title">{cat.data.title} in {b.address.city}</h2>
          <p>
            {cat.data.homepageBlurb}{' '}
            <a href={`/services/${cat.id}/`}>
              Explore our {cat.data.title.toLowerCase()} services in {b.address.city}
            </a>.
          </p>
        </article>
      ))}
    </div>
  </section>

  <!-- 8. OPTIONAL: live availability / truthful-urgency / pricing band.
       Uncomment and wire per business where applicable (Rule 13 #8).
  <section class="section section--alt">
    <div class="container">
      <h2>Current Availability</h2>
      <p>[Truthful urgency only: real open slots, real waitlist status, never fake scarcity.]</p>
    </div>
  </section>
  -->

  <!-- 9. Embedded live GBP reviews -->
  <ReviewsEmbed />

  <!-- 10. FAQ, fully visible on load, FAQPage schema auto-emitted -->
  <FAQ faqs={hp.faqs} heading={`${b.primaryCategory} Questions from ${b.address.city} Customers`} />

  <!-- Service-areas strip: renders only when town pages exist -->
  <ServiceAreas />

  <!-- 11. Google Maps embed + NAP block (character-for-character) -->
  <MapNAP />

  <!-- 12. Final CTA -->
  <CTA />
</BaseLayout>
