---
/**
 * ═══════════════════════════════════════════════════════════════════
 * HOMEPAGE = THE GBP LANDING PAGE (the URL in the GBP's website field).
 * Implements the Rule 13 blueprint in exact order, and carries all 8
 * Rule 12 consistency signals:
 *   1. Title tag: primary category + city (formula below)
 *   2. H1: primary category + city + hook (homepage.ts)
 *   3. Google Maps embed of the GBP pin (MapNAP)
 *   4. Secondary categories in H2 subheadings (category loop)
 *   5. Live GBP review widget (ReviewsEmbed)
 *   6. Address matching GBP character-for-character (config-driven)
 *   7. Phone matching character-for-character (config-driven)
 *   8. LocalBusiness schema (BaseLayout → LocalBusinessSchema)
 * ═══════════════════════════════════════════════════════════════════
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ReviewsEmbed from '../components/ReviewsEmbed.astro';
import FAQ from '../components/FAQ.astro';
import MapNAP from '../components/MapNAP.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import CTA from '../components/CTA.astro';
import { business as b, cityState } from '../config/business';
import { homepage as hp } from '../config/homepage';

// Rule 17 title formula: [Primary GBP category] + [City, ST] + [Brand],
// with the optional long-title keyword tail appended past truncation.
const title =
  `${b.primaryCategory} in ${cityState} | ${b.name}` +
  (b.seo.titleTail ? ` | ${b.seo.titleTail}` : '');

const categories = (await getCollection('categories')).sort(
  (a, z) => a.data.order - z.data.order
);

// Why Choose Us stroke icons, inlined (zero external requests). All share
// the 256 grid and a 16px stroke so they sit as one matched set.
const whyIcons: Record<string, string> = {
  leaf:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="none" aria-hidden="true">' +
    '<g stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16">' +
    '<path d="M63.81,192.19c-47.89-79.81,16-159.62,151.64-151.64C223.43,176.23,143.62,240.08,63.81,192.19Z"/>' +
    '<line x1="160" y1="96" x2="40" y2="216"/>' +
    '</g></svg>',
  book:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="none" aria-hidden="true">' +
    '<g stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16">' +
    '<polyline points="176 32 176 128 143.99 104 112 128 112 32"/>' +
    '<path d="M48,216a24,24,0,0,1,24-24H208V32H72A24,24,0,0,0,48,56Z"/>' +
    '<polyline points="48 216 48 224 192 224"/>' +
    '</g></svg>',
  handshake:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="none" aria-hidden="true">' +
    '<g stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16">' +
    '<polyline points="200 152 160 192 96 176 40 136"/>' +
    '<polyline points="72.68 70.63 128 56 183.32 70.63"/>' +
    '<path d="M34.37,60.42,8.85,111.48a8,8,0,0,0,3.57,10.73L40,136,72.68,70.63,45.11,56.85A8,8,0,0,0,34.37,60.42Z"/>' +
    '<path d="M216,136l27.58-13.79a8,8,0,0,0,3.57-10.73L221.63,60.42a8,8,0,0,0-10.74-3.57L183.32,70.63Z"/>' +
    '<path d="M184,72H144L98.34,116.29a8,8,0,0,0,1.38,12.42C117.23,139.9,141,139.13,160,120l40,32,16-16"/>' +
    '<polyline points="124.06 216 82.34 205.57 56 186.75"/>' +
    '</g></svg>',
  crosshair:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="none" aria-hidden="true">' +
    '<g stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16">' +
    '<line x1="128" y1="232" x2="128" y2="200"/>' +
    '<circle cx="128" cy="128" r="88"/>' +
    '<line x1="128" y1="24" x2="128" y2="56"/>' +
    '<line x1="24" y1="128" x2="56" y2="128"/>' +
    '<line x1="232" y1="128" x2="200" y2="128"/>' +
    '<circle cx="128" cy="128" r="32"/>' +
    '</g></svg>',
};
---

<BaseLayout title={title} description={b.seo.homepageMetaDescription}>
  <!-- 1–3. H1 + subheadline + primary CTA + tap-to-call phone, above the fold -->
  <Hero h1={hp.hero.h1} benefits={hp.hero.benefits} reviewers={hp.googleReviewers} pillText={hp.hero.pillText} ctaLabel={hp.hero.ctaLabel} image={hp.hero.image} />

  <!-- 4. Social-proof band: rating + review count + badges -->

  <!-- 5. Opening paragraph: visitor's situation + USP (Rule 21, never "Welcome to…") -->
  <section class="section">
    <div class="container intro-split">
      <div class="intro-split__text">
        <h2>{hp.introH2}</h2>
        <p class="lead">{hp.openingParagraph}</p>
      </div>
      <picture class="intro-split__media">
        <source media="(max-width: 63.99rem)" srcset="/images/bucket-truck-pine-removal-residential-street-pasadena-tx-mobile.webp" width="768" height="633" />
      <img
        class="intro-split__img"
        src="/images/bucket-truck-pine-removal-residential-street-pasadena-tx.webp"
        alt="Gulf Coast Tree Removal arborist working from a fully extended bucket truck to remove a tall pine on a residential street in Pasadena, TX"
        width="765" height="1020" loading="lazy" decoding="async"
      />
      </picture>
    </div>
  </section>

  <!-- 6. Why Choose Us, high on the page, static grid (no carousel) -->
  <section class="section section--alt">
    <div class="container">
      <p class="eyebrow">Why choose us</p>
      <h2>Why {b.address.city} Chooses {b.name}</h2>
      <div class="why-grid">
        {hp.whyChooseUs.map((item) => (
          <div class="card card--why">
            <span class="why-icon" set:html={whyIcons[item.icon]} />
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. Secondary category sections: each GBP category gets an H2 +
       50–100 words + an EDITORIAL link (in-paragraph) to its category
       page, the links that actually pass authority (Rule 16). -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">What we do</p>
      <h2>Our Tree Services in {b.address.city}</h2>
      <div class="cat-grid">
        {categories.map((cat) => (
          <article class="card card--flow">
            <h2 class="card-title">{cat.data.title}</h2>
            <p>
              {cat.data.homepageBlurb}{' '}
              <a href={`/services/${cat.id}/`}>
                Explore our {cat.data.title.toLowerCase()} services in {b.address.city}
              </a>.
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. OPTIONAL: live availability / truthful-urgency / pricing band.
       Uncomment and wire per business where applicable (Rule 13 #8).
  <section class="section section--alt">
    <div class="container">
      <h2>Current Availability</h2>
      <p>[Truthful urgency only: real open slots, real waitlist status, never fake scarcity.]</p>
    </div>
  </section>
  -->

  <!-- 9. Embedded live GBP reviews -->
  <ReviewsEmbed />

  <!-- 10. FAQ, fully visible on load, FAQPage schema auto-emitted -->
  <FAQ faqs={hp.faqs} heading={`${b.primaryCategory} Questions from ${b.address.city} Customers`} />

  <!-- Service-areas strip: renders only when town pages exist -->
  <ServiceAreas />

  <!-- 11. Google Maps embed + NAP block (character-for-character) -->
  <MapNAP />

  <!-- 12. Final CTA -->
  <CTA />
</BaseLayout>
